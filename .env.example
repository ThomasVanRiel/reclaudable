# reclaudable configuration — copy to `.env` and edit for your host.
# Read by config.py (Python) and bin/rmapi (shell). Values already set in the
# real environment take precedence. Quotes are optional.

# --- rmfakecloud storage (sync15 reader) ---
# Your rmfakecloud username and Docker container name. SYNC_DIR is the blob
# store inside the container; the default derives from RM_USER and is usually
# correct, so only set it if your layout differs.
RECLAUDABLE_RM_USER=your-rmfakecloud-username
RECLAUDABLE_CONTAINER=rmfakecloud
#RECLAUDABLE_SYNC_DIR=/data/users/your-rmfakecloud-username/sync

# --- conversation behaviour ---
# Device folder to watch (case-insensitive); label shown on each reply; and the
# stable working dir for the headless reply-Claude (sessions are keyed by cwd —
# keep it constant, and outside the repo so this project's CLAUDE.md never loads).
RECLAUDABLE_FOLDER=Claude
RECLAUDABLE_MODEL_LABEL=Claude Opus 4.8
#RECLAUDABLE_CLAUDE_CWD=/home/you/.reclaudable/claude-cwd
# Path to the `claude` CLI. Defaults to "claude" (resolved on PATH, fine for the
# watcher). Set an absolute path so the import skill's non-interactive SSH — whose
# PATH omits ~/.local/bin — can find it (`which claude` to locate it).
#RECLAUDABLE_CLAUDE_BIN=/home/you/.local/bin/claude

# --- rmapi write-back ---
# Your self-hosted rmfakecloud URL and the path to the rmapi binary you built.
RECLAUDABLE_RMAPI_HOST=https://remarkable.example.com
RECLAUDABLE_RMAPI_BIN=/home/you/source/rmapi/rmapi

# --- email a report ---
# Used when a page asks you to "email me the report". SMTP delivery; you can copy
# these straight from rmfakecloud's RM_SMTP_* values (kept separate on purpose).
# Server is "host:port" — port 465 = implicit TLS, 587 = STARTTLS. FROM defaults
# to the username; EMAIL_TO (the fixed "me" recipient) defaults to FROM.
RECLAUDABLE_SMTP_SERVER=smtp.gmail.com:465
RECLAUDABLE_SMTP_USERNAME=you@gmail.com
RECLAUDABLE_SMTP_PASSWORD=your-gmail-app-password
#RECLAUDABLE_SMTP_FROM=you@gmail.com
#RECLAUDABLE_EMAIL_TO=you@gmail.com
